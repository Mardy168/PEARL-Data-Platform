# ==========================================================
# Python
# ==========================================================

__pycache__/
*.py[cod]
*.pyo
*.pyd
*$py.class

# ==========================================================
# Virtual environments
# ==========================================================

.env
.env.*
.venv/
venv/

# ==========================================================
# Testing
# ==========================================================

.pytest_cache/

# ==========================================================
# OS
# ==========================================================

.DS_Store
Thumbs.db

# ==========================================================
# Credentials (Never upload)
# ==========================================================

service_account.json
credentials.json
client_secret*.json
*.pem
*.key

# ==========================================================
# Generated Data
# ==========================================================

data/daily/*
data/weekly/*
data/monthly/*
data/logs/*
data/master/*
data/qa/*
data/raw_archive/*
data/master_backups/*

# ==========================================================
# Keep empty folders
# ==========================================================

!data/daily/.gitkeep
!data/weekly/.gitkeep
!data/monthly/.gitkeep
!data/logs/.gitkeep
!data/master/.gitkeep
!data/qa/.gitkeep
!data/raw_archive/.gitkeep
!data/master_backups/.gitkeep
